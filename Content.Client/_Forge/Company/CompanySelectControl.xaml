<BoxContainer xmlns="https://spacestation14.io"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
              x:Class="Content.Client._Forge.Company.UI.CompanySelectControl"
              Orientation="Horizontal"
              SeparationOverride="10"
              Margin="10"
              VerticalExpand="True">
    <PanelContainer StyleClasses="BackgroundDark"
                    MinSize="340 0"
                    MaxSize="340 10000"
                    HorizontalExpand="False"
                    VerticalExpand="True">
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Name="CompanyListContainer" Orientation="Vertical" Margin="6"/>
        </ScrollContainer>
    </PanelContainer>

    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer Name="CompanyActionsPanel"
                        StyleClasses="BackgroundDark"
                        HorizontalExpand="True"
                        Margin="0 0 0 8">
            <BoxContainer Orientation="Horizontal" Margin="8" SeparationOverride="8">
                <Button Name="JoinCompanyButton"
                        Text="{Loc 'company-select-button'}"
                        HorizontalExpand="True"/>
                <Button Name="LeaveCompanyButton"
                        Text="{Loc 'company-leave-button'}"
                        HorizontalExpand="True"/>
            </BoxContainer>
                <controls:StripeBack Name="CompanyLockedStripe"
                                    Visible="False"
                                    HorizontalExpand="True"
                                    VerticalExpand="True">
                    <Label Name="CompanyLockedLabel"
                        Text="{Loc 'company-no-logins-tooltip'}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </controls:StripeBack>
        </PanelContainer>

        <PanelContainer Name="CompanyDescriptionPanel"
                        StyleClasses="BackgroundDark"
                        HorizontalExpand="True"
                        VerticalExpand="True">
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                <RichTextLabel Name="CompanyDescription"
                               Access="Public"
                               VerticalAlignment="Top"
                               StyleClasses="LabelSubText LabelLarge"
                               Margin="10 12 10 8"
                               HorizontalExpand="True"
                               VerticalExpand="True" />
            </ScrollContainer>
        </PanelContainer>

        <PanelContainer Name="CompanyNotePanel"
                        StyleClasses="BackgroundDark"
                        HorizontalExpand="True"
                        VerticalExpand="False"
                        MinSize="0 200"
                        Margin="0 8 0 0"
                        Visible="False">
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                <RichTextLabel Name="CompanyNote"
                               Access="Public"
                               VerticalAlignment="Top"
                               StyleClasses="LabelSubText LabelLarge"
                               Margin="10 12 10 8"
                               HorizontalExpand="True"
                               VerticalExpand="True" />
            </ScrollContainer>
        </PanelContainer>
    </BoxContainer>
</BoxContainer>
